# Compiled / generated artifacts (regenerable)
*.class
*.jasper
__pycache__/

# Microsoft Office owner-lock temp files (created while a doc is open)
~$*

# Large regenerable data exports (rebuild from the DB)
output/

# Report-verification PDFs (re-run reports to regenerate)
out_verify/
out/

# Vendor docs: full JasperReports Server 10.0.0 PDF set (~62 MB, machine-local,
# freely re-downloadable from Jaspersoft). Referenced by the jasper-deploy skill
# but kept out of the repo like the jasperreports-lib jars.
docs/

