<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="county_summary" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT c.name AS county, l.countyfp, count(*)::int AS edge_count, round(avg(st_length(l.the_geom))::numeric,2) AS avg_edge_len FROM tiger_data.tx_edges l JOIN tiger.county c ON c.statefp='48' AND c.countyfp=l.countyfp GROUP BY 1,2 ORDER BY edge_count DESC
	]]></query>

	<field name="county" class="java.lang.String"/>
	<field name="countyfp" class="java.lang.String"/>
	<field name="edge_count" class="java.lang.Integer"/>
	<field name="avg_edge_len" class="java.math.BigDecimal"/>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true"><text><![CDATA[Texas County Edge Summary]]></text></element>
		<element kind="staticText" x="0" y="26" width="555" height="14" fontSize="9.0" forecolor="#666666"><text><![CDATA[Top counties by TIGER edge count (postgis_34_sample)]]></text></element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="555" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="164" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[County]]></text></element>
		<element kind="staticText" x="176" y="0" width="164" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[Countyfp]]></text></element>
		<element kind="staticText" x="340" y="0" width="100" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Edge Count]]></text></element>
		<element kind="staticText" x="446" y="0" width="103" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Avg Edge Len]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="164" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{county}]]></expression></element>
		<element kind="textField" x="176" y="0" width="164" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{countyfp}]]></expression></element>
		<element kind="textField" x="340" y="0" width="100" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{edge_count}]]></expression></element>
		<element kind="textField" x="446" y="0" width="103" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.00"><expression><![CDATA[$F{avg_edge_len}]]></expression></element>
			<element kind="line" x="0" y="12" width="555" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="277" height="12" fontSize="8.0" forecolor="#666666"><text><![CDATA[Texas County Edge Summary]]></text></element>
