<?xml version="1.0" encoding="UTF-8"?>
<!-- CSV-data-adapter report. Reads its rows from a repository CSV via a .jrdax
     data adapter (no JDBC datasource, no <query>). The main dataset binds to the
     adapter through the net.sf.jasperreports.data.adapter property; fields map to
     CSV columns by header name (useFirstRowAsHeader=true). JR7-native. -->
<jasperReport name="csv_metro_pop" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="net.sf.jasperreports.data.adapter" value="repo:/reports/geocoder/data/metro_pop_adapter.jrdax"/>

	<field name="metro" class="java.lang.String"/>
	<field name="population" class="java.lang.Integer"/>

	<variable name="total" class="java.lang.Long" calculation="Sum">
		<expression><![CDATA[$F{population}.longValue()]]></expression>
	</variable>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true" hTextAlign="Center"><text><![CDATA[Texas Metro Population (from CSV data adapter)]]></text></element>
		<element kind="staticText" x="0" y="26" width="555" height="14" fontSize="9.0" forecolor="#666666" hTextAlign="Center"><text><![CDATA[Rows read from repo:/reports/geocoder/data/metro_pop.csv via a .jrdax CSV adapter]]></text></element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="555" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="380" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" vTextAlign="Middle"><text><![CDATA[Metropolitan Area]]></text></element>
		<element kind="staticText" x="386" y="0" width="163" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Population]]></text></element>
	</columnHeader>

	<detail>
		<band height="15">
			<element kind="textField" x="6" y="0" width="380" height="15" fontSize="9.0" vTextAlign="Middle"><expression><![CDATA[$F{metro}]]></expression></element>
			<element kind="textField" x="386" y="0" width="163" height="15" fontSize="9.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{population}]]></expression></element>
			<element kind="line" x="0" y="14" width="555" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<summary height="24">
		<element kind="staticText" x="6" y="4" width="380" height="16" fontSize="9.0" bold="true"><text><![CDATA[Total]]></text></element>
		<element kind="textField" x="386" y="4" width="163" height="16" fontSize="9.0" bold="true" hTextAlign="Right" pattern="#,##0"><expression><![CDATA[$V{total}]]></expression></element>
	</summary>

</jasperReport>
