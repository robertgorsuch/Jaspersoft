<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="tx_addr_zip_summary" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT zip, count(*)::int AS addr_ranges, count(DISTINCT tlid)::int AS street_segments, count(*) FILTER (WHERE side='L')::int AS left_side, count(*) FILTER (WHERE side='R')::int AS right_side, count(*) FILTER (WHERE plus4 IS NOT NULL AND plus4 <> '')::int AS with_plus4 FROM tiger_data.tx_addr WHERE zip IS NOT NULL GROUP BY zip ORDER BY addr_ranges DESC
	]]></query>

	<field name="zip" class="java.lang.String"/>
	<field name="addr_ranges" class="java.lang.Integer"/>
	<field name="street_segments" class="java.lang.Integer"/>
	<field name="left_side" class="java.lang.Integer"/>
	<field name="right_side" class="java.lang.Integer"/>
	<field name="with_plus4" class="java.lang.Integer"/>

