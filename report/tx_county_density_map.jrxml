<?xml version="1.0" encoding="UTF-8"?>
<!--
  Texas population density choropleth by county. PRO FusionMaps component
  (legacy 6.x jrxml, fm:map namespace) rendered server-side by JasperReports
  Server. The installed "Texas" map (fusion/maps/fusioncharts.texas.js) is keyed
  by county FIPS, so idExpression binds straight to (countyfp::int)::text.
  NOT locally compilable - validate by deploy + run on the server.
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="tx_county_density_map" pageWidth="842" pageHeight="595" columnWidth="802"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="c1d2e3f4-0010-0002-0003-000000000001">
	<queryString><![CDATA[SELECT (b.countyfp::int)::text AS map_id, c.name AS county, round((p.pop / b.land_km2)::numeric, 1) AS density FROM (SELECT countyfp, sum(aland)/1000000.0 AS land_km2 FROM tiger_data.tx_bg GROUP BY countyfp) b JOIN (SELECT countyfp, sum(pop) AS pop FROM tiger_data.tx_tabblock20 GROUP BY countyfp) p ON p.countyfp = b.countyfp JOIN tiger.county c ON c.statefp = '48' AND c.countyfp = b.countyfp WHERE b.land_km2 > 0 ORDER BY density DESC]]></queryString>
	<field name="map_id" class="java.lang.String"/>
	<field name="county" class="java.lang.String"/>
	<field name="density" class="java.math.BigDecimal"/>
	<title>
		<band height="540">
			<staticText>
				<reportElement x="0" y="0" width="802" height="26" uuid="c1d2e3f4-0010-0002-0003-000000000002"/>
				<textElement><font size="16" isBold="true"/></textElement>
				<text><![CDATA[Texas Population Density by County (people / km2)]]></text>
			</staticText>
			<staticText>
				<reportElement x="0" y="26" width="802" height="14" forecolor="#666666" uuid="c1d2e3f4-0010-0002-0003-000000000003"/>
				<textElement><font size="9"/></textElement>
				<text><![CDATA[FusionMaps choropleth (Pro), rendered server-side. 2020 Census blocks over TIGER county land area.]]></text>
			</staticText>
			<componentElement>
				<reportElement x="0" y="46" width="802" height="490" uuid="c1d2e3f4-0010-0002-0003-000000000004"/>
				<fm:map xmlns:fm="http://jaspersoft.com/fusion"
				        xsi:schemaLocation="http://jaspersoft.com/fusion http://jaspersoft.com/schema/fusion.xsd"
				        evaluationTime="Report">
					<fm:mapNameExpression><![CDATA["Texas"]]></fm:mapNameExpression>
					<fm:mapProperty name="includeNameInLabels">
						<fm:propertyExpression><![CDATA[Boolean.FALSE]]></fm:propertyExpression>
					</fm:mapProperty>
					<fm:mapProperty name="showLabels">
						<fm:propertyExpression><![CDATA[Boolean.FALSE]]></fm:propertyExpression>
					</fm:mapProperty>
					<fm:mapProperty name="numberSuffix">
						<fm:propertyExpression><![CDATA[" /km2"]]></fm:propertyExpression>
					</fm:mapProperty>
					<fm:mapProperty name="legendPosition">
						<fm:propertyExpression><![CDATA["BOTTOM"]]></fm:propertyExpression>
					</fm:mapProperty>
					<fm:colorRange color="#FFEDA0">
						<fm:minValueExpression><![CDATA[0]]></fm:minValueExpression>
						<fm:maxValueExpression><![CDATA[50]]></fm:maxValueExpression>
						<fm:labelExpression><![CDATA["< 50"]]></fm:labelExpression>
					</fm:colorRange>
					<fm:colorRange color="#FEB24C">
						<fm:minValueExpression><![CDATA[50]]></fm:minValueExpression>
						<fm:maxValueExpression><![CDATA[200]]></fm:maxValueExpression>
						<fm:labelExpression><![CDATA["50 - 200"]]></fm:labelExpression>
					</fm:colorRange>
					<fm:colorRange color="#FD8D3C">
						<fm:minValueExpression><![CDATA[200]]></fm:minValueExpression>
						<fm:maxValueExpression><![CDATA[500]]></fm:maxValueExpression>
						<fm:labelExpression><![CDATA["200 - 500"]]></fm:labelExpression>
					</fm:colorRange>
					<fm:colorRange color="#FC4E2A">
						<fm:minValueExpression><![CDATA[500]]></fm:minValueExpression>
						<fm:maxValueExpression><![CDATA[1000]]></fm:maxValueExpression>
						<fm:labelExpression><![CDATA["500 - 1,000"]]></fm:labelExpression>
					</fm:colorRange>
					<fm:colorRange color="#800026">
						<fm:minValueExpression><![CDATA[1000]]></fm:minValueExpression>
						<fm:maxValueExpression><![CDATA[20000]]></fm:maxValueExpression>
						<fm:labelExpression><![CDATA["1,000+"]]></fm:labelExpression>
					</fm:colorRange>
					<fm:mapDataset>
						<fm:entity>
							<fm:idExpression><![CDATA[$F{map_id}]]></fm:idExpression>
							<fm:valueExpression><![CDATA[$F{density}]]></fm:valueExpression>
						</fm:entity>
					</fm:mapDataset>
					<fm:shapeData/>
					<c:markerData xmlns:c="http://jasperreports.sourceforge.net/jasperreports/components"
					              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd"/>
				</fm:map>
			</componentElement>
		</band>
	</title>
</jasperReport>
