<?xml version="1.0" encoding="UTF-8"?>
<!--
  Texas Population Density by Census Block Group (2020) - NATIVE JasperReports 7 format.
  Based on tx_density_choropleth_blockgroup.html. Compiles with JasperReports 7.0.6.
  Run against a JDBC connection to PostgreSQL database 'postgis_34_sample'.
-->
<jasperReport name="tx_density_blockgroup_report" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT
  COALESCE(c.name,'(unknown)')                            AS county,
  l.geoid                                                 AS block_group,
  l.pop::bigint                                           AS population,
  l.area_km2                                              AS area_km2,
  round(l.dens::numeric,1)                                AS density,
  l.density_class                                         AS density_class,
  count(*)   over (partition by l.density_class)::int     AS class_bg_count,
  sum(l.pop) over (partition by l.density_class)::bigint  AS class_pop,
  round((100.0 * sum(l.pop) over (partition by l.density_class)
        / NULLIF(sum(l.pop) over (),0))::numeric,1)        AS class_pct
FROM (
  SELECT geoid, statefp, countyfp, pop,
         round((aland/1e6)::numeric,3) AS area_km2,
         CASE WHEN aland>0 THEN pop/(aland/1e6) ELSE 0 END AS dens,
         CASE
           WHEN aland=0 OR pop=0       THEN '1. < 50'
           WHEN pop/(aland/1e6) < 50   THEN '1. < 50'
           WHEN pop/(aland/1e6) < 200  THEN '2. 50 - 200'
           WHEN pop/(aland/1e6) < 500  THEN '3. 200 - 500'
           WHEN pop/(aland/1e6) < 1000 THEN '4. 500 - 1,000'
           WHEN pop/(aland/1e6) < 2000 THEN '5. 1,000 - 2,000'
           WHEN pop/(aland/1e6) < 4000 THEN '6. 2,000 - 4,000'
           WHEN pop/(aland/1e6) < 8000 THEN '7. 4,000 - 8,000'
           ELSE '8. 8,000+'
         END AS density_class
  FROM (
    SELECT b.geoid, b.statefp, b.countyfp, b.aland, COALESCE(a.pop,0) AS pop
    FROM tiger_data.tx_bg b
    LEFT JOIN (
      SELECT statefp||countyfp||tractce||left(blockce,1) AS bg, sum(pop) AS pop
      FROM tiger_data.tx_tabblock20 GROUP BY 1
    ) a ON a.bg = b.geoid
  ) bgpop
) l
LEFT JOIN tiger.county c ON c.statefp=l.statefp AND c.countyfp=l.countyfp
ORDER BY l.density_class, county, l.geoid
	]]></query>

	<field name="county" class="java.lang.String"/>
	<field name="block_group" class="java.lang.String"/>
	<field name="population" class="java.lang.Long"/>
	<field name="area_km2" class="java.math.BigDecimal"/>
	<field name="density" class="java.math.BigDecimal"/>
	<field name="density_class" class="java.lang.String"/>
	<field name="class_bg_count" class="java.lang.Integer"/>
	<field name="class_pop" class="java.lang.Long"/>
	<field name="class_pct" class="java.math.BigDecimal"/>

	<variable name="totPop" class="java.lang.Long" calculation="Sum">
		<expression><![CDATA[$F{population}]]></expression>
	</variable>
	<variable name="totCount" class="java.lang.Integer" calculation="Count">
		<expression><![CDATA[$F{block_group}]]></expression>
	</variable>

	<group name="DensityClass">
		<expression><![CDATA[$F{density_class}]]></expression>
		<groupHeader>
			<band height="24">
				<element kind="rectangle" x="0" y="3" width="555" height="18" mode="Opaque" backcolor="#EFEFEF" forecolor="#EFEFEF"/>
				<element kind="textField" x="6" y="3" width="230" height="18" fontSize="11.0" bold="true" vTextAlign="Middle">
					<expression><![CDATA[$F{density_class} + "  people/km2"]]></expression>
				</element>
				<element kind="textField" x="236" y="3" width="313" height="18" fontSize="9.0" hTextAlign="Right" vTextAlign="Middle">
					<expression><![CDATA[java.text.NumberFormat.getIntegerInstance().format($F{class_bg_count}) + " block groups   |   " + java.text.NumberFormat.getIntegerInstance().format($F{class_pop}) + " people   |   " + $F{class_pct} + "% of state   "]]></expression>
				</element>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="6">
				<element kind="line" x="0" y="1" width="555" height="1" forecolor="#CCCCCC"/>
			</band>
		</groupFooter>
	</group>

	<title height="208">
		<element kind="textField" x="0" y="0" width="555" height="26" fontSize="17.0" bold="true">
			<expression><![CDATA["Texas Population Density by Census Block Group"]]></expression>
		</element>
		<element kind="staticText" x="0" y="28" width="555" height="15" fontSize="10.0">
			<text><![CDATA[2020 Census - TIGER/Line block groups, classified by population density (people per km2)]]></text>
		</element>
		<element kind="staticText" x="0" y="44" width="555" height="12" fontSize="7.5" forecolor="#666666">
			<text><![CDATA[Source: PostgreSQL postgis_34_sample - tiger_data.tx_bg joined to block-summed population from tiger_data.tx_tabblock20. Based on tx_density_choropleth_blockgroup.html.]]></text>
		</element>
		<element kind="staticText" x="0" y="66" width="300" height="14" fontSize="10.0" bold="true">
			<text><![CDATA[Density classes (people / km2)]]></text>
		</element>
		<element kind="rectangle" x="0" y="84"  width="16" height="11" mode="Opaque" backcolor="#FFEDA0" forecolor="#999999"/>
		<element kind="staticText" x="20" y="84"  width="200" height="11" fontSize="8.0"><text><![CDATA[< 50]]></text></element>
		<element kind="rectangle" x="0" y="98"  width="16" height="11" mode="Opaque" backcolor="#FED976" forecolor="#999999"/>
		<element kind="staticText" x="20" y="98"  width="200" height="11" fontSize="8.0"><text><![CDATA[50 - 200]]></text></element>
		<element kind="rectangle" x="0" y="112" width="16" height="11" mode="Opaque" backcolor="#FEB24C" forecolor="#999999"/>
		<element kind="staticText" x="20" y="112" width="200" height="11" fontSize="8.0"><text><![CDATA[200 - 500]]></text></element>
		<element kind="rectangle" x="0" y="126" width="16" height="11" mode="Opaque" backcolor="#FD8D3C" forecolor="#999999"/>
		<element kind="staticText" x="20" y="126" width="200" height="11" fontSize="8.0"><text><![CDATA[500 - 1,000]]></text></element>
		<element kind="rectangle" x="280" y="84"  width="16" height="11" mode="Opaque" backcolor="#FC4E2A" forecolor="#999999"/>
		<element kind="staticText" x="300" y="84"  width="200" height="11" fontSize="8.0"><text><![CDATA[1,000 - 2,000]]></text></element>
		<element kind="rectangle" x="280" y="98"  width="16" height="11" mode="Opaque" backcolor="#E31A1C" forecolor="#999999"/>
		<element kind="staticText" x="300" y="98"  width="200" height="11" fontSize="8.0"><text><![CDATA[2,000 - 4,000]]></text></element>
		<element kind="rectangle" x="280" y="112" width="16" height="11" mode="Opaque" backcolor="#BD0026" forecolor="#999999"/>
		<element kind="staticText" x="300" y="112" width="200" height="11" fontSize="8.0"><text><![CDATA[4,000 - 8,000]]></text></element>
		<element kind="rectangle" x="280" y="126" width="16" height="11" mode="Opaque" backcolor="#800026" forecolor="#999999"/>
		<element kind="staticText" x="300" y="126" width="200" height="11" fontSize="8.0"><text><![CDATA[8,000 +]]></text></element>
		<element kind="line" x="0" y="150" width="555" height="1" forecolor="#999999"/>
		<element kind="textField" x="0" y="156" width="555" height="14" fontSize="9.0" italic="true">
			<expression><![CDATA["Generated " + new java.text.SimpleDateFormat("yyyy-MM-dd HH:mm").format(new java.util.Date())]]></expression>
		</element>
	</title>

	<columnHeader height="18">
		<element kind="rectangle" x="0" y="0" width="555" height="18" mode="Opaque" backcolor="#34495E" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="0" width="194" height="18" forecolor="#FFFFFF" fontSize="9.0" bold="true" vTextAlign="Middle"><text><![CDATA[County]]></text></element>
		<element kind="staticText" x="200" y="0" width="100" height="18" forecolor="#FFFFFF" fontSize="9.0" bold="true" vTextAlign="Middle"><text><![CDATA[Block Group]]></text></element>
		<element kind="staticText" x="300" y="0" width="80" height="18" forecolor="#FFFFFF" fontSize="9.0" bold="true" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Population]]></text></element>
		<element kind="staticText" x="380" y="0" width="80" height="18" forecolor="#FFFFFF" fontSize="9.0" bold="true" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Area (km2)]]></text></element>
		<element kind="staticText" x="460" y="0" width="89" height="18" forecolor="#FFFFFF" fontSize="9.0" bold="true" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Density /km2]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
			<element kind="textField" x="6" y="0" width="194" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{county}]]></expression></element>
			<element kind="textField" x="200" y="0" width="100" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{block_group}]]></expression></element>
			<element kind="textField" x="300" y="0" width="80" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{population}]]></expression></element>
			<element kind="textField" x="380" y="0" width="80" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.000"><expression><![CDATA[$F{area_km2}]]></expression></element>
			<element kind="textField" x="460" y="0" width="89" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0.0"><expression><![CDATA[$F{density}]]></expression></element>
			<element kind="line" x="0" y="12" width="555" height="1" forecolor="#EEEEEE"/>
		</band>
	</detail>

	<pageFooter height="16">
		<element kind="staticText" x="0" y="2" width="277" height="12" forecolor="#666666" fontSize="8.0"><text><![CDATA[Texas Population Density - Block Group Report]]></text></element>
		<element kind="textField" x="400" y="2" width="120" height="12" forecolor="#666666" fontSize="8.0" hTextAlign="Right"><expression><![CDATA["Page " + $V{PAGE_NUMBER} + " of"]]></expression></element>
		<element kind="textField" x="522" y="2" width="33" height="12" forecolor="#666666" fontSize="8.0" evaluationTime="Report"><expression><![CDATA[" " + $V{PAGE_NUMBER}]]></expression></element>
	</pageFooter>

	<summary height="46">
		<element kind="line" x="0" y="2" width="555" height="1" forecolor="#34495E"/>
		<element kind="staticText" x="6" y="8" width="200" height="16" fontSize="11.0" bold="true"><text><![CDATA[Statewide total]]></text></element>
		<element kind="textField" x="206" y="8" width="343" height="16" fontSize="11.0" bold="true" hTextAlign="Right"><expression><![CDATA[java.text.NumberFormat.getIntegerInstance().format($V{totCount}) + " block groups     " + java.text.NumberFormat.getIntegerInstance().format($V{totPop}) + " people"]]></expression></element>
		<element kind="staticText" x="6" y="26" width="543" height="14" forecolor="#666666" fontSize="8.0" italic="true"><text><![CDATA[Density = block-group population / land area (km2). Classes match the choropleth legend.]]></text></element>
	</summary>

</jasperReport>
