		<element kind="staticText" x="313" y="0" width="114" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Road Segments]]></text></element>
		<element kind="staticText" x="433" y="0" width="116" height="18" fontSize="9.0" bold="true" forecolor="#FFFFFF" hTextAlign="Right" vTextAlign="Middle"><text><![CDATA[Name Records]]></text></element>
	</columnHeader>

	<detail>
		<band height="13">
		<element kind="textField" x="6" y="0" width="187" height="13" fontSize="8.0" vTextAlign="Middle"><expression><![CDATA[$F{street_name}]]></expression></element>
		<element kind="textField" x="193" y="0" width="114" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{distinct_streets}]]></expression></element>
		<element kind="textField" x="313" y="0" width="114" height="13" fontSize="8.0" hTextAlign="Right" vTextAlign="Middle" pattern="#,##0"><expression><![CDATA[$F{road_segments}]]></expression></element>
