<?xml version="1.0" encoding="UTF-8"?>
<!-- Generated by jasper-deploy scaffold_jrxml.py. JR7-native (JasperReports 7.0.6). -->
<jasperReport name="tx_featnames_top_streets" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<query language="SQL"><![CDATA[
SELECT fullname AS street_name, count(DISTINCT linearid)::int AS distinct_streets, count(DISTINCT tlid)::int AS road_segments, count(*)::int AS name_records FROM tiger_data.tx_featnames WHERE fullname IS NOT NULL AND mtfcc LIKE 'S%' GROUP BY fullname ORDER BY distinct_streets DESC, name_records DESC LIMIT 200
	]]></query>

	<field name="street_name" class="java.lang.String"/>
	<field name="distinct_streets" class="java.lang.Integer"/>
	<field name="road_segments" class="java.lang.Integer"/>
	<field name="name_records" class="java.lang.Integer"/>

	<title height="44">
		<element kind="staticText" x="0" y="0" width="555" height="24" fontSize="16.0" bold="true"><text><![CDATA[Most Common Street Names in Texas]]></text></element>
		<element kind="staticText" x="0" y="26" width="555" height="14" fontSize="9.0" forecolor="#666666"><text><![CDATA[Top 200 street names from tiger_data.tx_featnames (TIGER feature names, road features only)]]></text></element>
	</title>

	<columnHeader height="18">
